{
    "name": "frontend",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve --proxy-config proxy.conf.json",
        "build": "ng build",
        "build:prod": "ng build --configuration=production",
        "deps:update:patch": "npx npm-check-updates@latest --target patch -u && npm install",
        "deps:update:minor": "npx npm-check-updates@latest --target minor -u && npm install",
        "deps:update:major": "npx npm-check-updates@latest --target latest -u && npm install",
        "format:prettier": "prettier --write \"src/**/*.html\"",
        "format:prettier:check": "prettier --check \"src/**/*.html\"",
        "format:biome": "biome format --write src eslint.config.ts tailwind.config.ts",
        "format:biome:check": "biome check src eslint.config.ts tailwind.config.ts --formatter-enabled=true --linter-enabled=false --assist-enabled=true",
        "lint": "eslint src --max-warnings=0",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --no-progress"
    },
    "prettier": {
        "printWidth": 120,
        "tabWidth": 4,
        "useTabs": false,
        "endOfLine": "auto",
        "semi": true,
        "singleQuote": true,
        "trailingComma": "all",
        "arrowParens": "always",
        "bracketSpacing": true,
        "overrides": [
            {
                "files": "**/*.html",
                "options": {
                    "printWidth": 9999,
                    "parser": "angular"
                }
            }
        ]
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "20.3.21",
        "@angular/common": "20.3.21",
        "@angular/compiler": "20.3.21",
        "@angular/core": "20.3.21",
        "@angular/forms": "20.3.21",
        "@angular/platform-browser": "20.3.21",
        "@angular/router": "20.3.21",
        "@fortawesome/fontawesome-free": "7.2.0",
        "@primeuix/themes": "1.2.5",
        "@tailwindcss/postcss": "4.3.0",
        "ag-grid-angular": "34.3.1",
        "ag-grid-community": "34.3.1",
        "apexcharts": "5.11.0",
        "ng-apexcharts": "2.4.0",
        "primeicons": "7.0.0",
        "primeng": "20.4.0",
        "rxjs": "7.8.2",
        "scichart": "5.2.11",
        "tailwindcss-primeui": "0.6.1",
        "tslib": "2.8.1",
        "zone.js": "0.16.2"
    },
    "devDependencies": {
        "@angular/build": "20.3.25",
        "@angular/cli": "20.3.25",
        "@angular/compiler-cli": "20.3.21",
        "@biomejs/biome": "2.4.15",
        "@eslint/js": "9.39.4",
        "@types/jasmine": "6.0.0",
        "angular-eslint": "20.7.0",
        "autoprefixer": "10.5.0",
        "eslint": "9.39.4",
        "eslint-plugin-perfectionist": "5.9.0",
        "jasmine-core": "6.2.0",
        "jiti": "2.7.0",
        "karma": "6.4.4",
        "karma-chrome-launcher": "3.2.0",
        "karma-coverage": "2.2.1",
        "karma-jasmine": "5.1.0",
        "karma-jasmine-html-reporter": "2.2.0",
        "postcss": "8.5.14",
        "prettier": "3.8.3",
        "tailwindcss": "4.3.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.59.3"
    }
}
